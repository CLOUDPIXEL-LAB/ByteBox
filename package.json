{
  "name": "@pinkpixel/bytebox",
  "author": "Pink Pixel",
  "description": "A dashboard app for developers",
  "version": "2.3.0",
  "type": "module",
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["/DEV/*", "node_modules"],
  "overrides": {
    "baseline-browser-mapping": "2.9.0-beta2",
    "hono": "^4.10.3",
    "valibot": "^1.1.1"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "node scripts/next-with-env.cjs dev 2>&1 | grep -v 'baseline-browser-mapping'",
    "build": "node scripts/next-with-env.cjs build 2>&1 | grep -v 'baseline-browser-mapping'",
    "start": "node scripts/next-with-env.cjs start 2>&1 | grep -v 'baseline-browser-mapping'",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
