{
  "name": "@pinkpixel/bytebox",
  "author": {
    "name": "Pink Pixel",
    "email": "admino@pinkpixel.dev",
    "url": "https://pinkpixel.dev"
  },
  "description": "A dashboard app for developers",
  "version": "2.4.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["/DEV/*", "node_modules"],
  "overrides": {
    "baseline-browser-mapping": "2.9.0-beta2",
    "hono": "^4.10.3",
    "valibot": "^1.1.1",
    "lodash": "4.17.23"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "node scripts/next-with-env.cjs dev 2>&1 | grep -v 'baseline-browser-mapping'",
    "build": "node scripts/next-with-env.cjs build 2>&1 | grep -v 'baseline-browser-mapping'",
    "start": "node scripts/next-with-env.cjs start 2>&1 | grep -v 'baseline-browser-mapping'",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "electron:compile": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --packages=external --outdir=dist-electron --out-extension:.js=.cjs",
    "electron:dev": "npm run electron:compile && concurrently -n \"next,electron\" -c \"cyan,magenta\" \"npm run dev\" \"wait-on http://localhost:1334 && electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:build:linux": "npm run build && npm run electron:compile && electron-builder --linux",
    "electron:build:win": "npm run build && npm run electron:compile && electron-builder --win",
    "electron:build:mac": "npm run build && npm run electron:compile && electron-builder --mac"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.1"
  }
}
